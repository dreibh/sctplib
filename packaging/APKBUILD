# Maintainer: Thomas Dreibholz <thomas.dreibholz@gmail.com>
pkgname=sctplib
pkgver=1.0.34
pkgrel=1
pkgdesc="User-space implementation of the SCTP protocol RFC 4960"
url="https://www.nntb.no/~dreibh/sctplib/"
arch="all"
license="LGPL-2.1-or-later"
depends=""
makedepends="autoconf automake libtool glib-dev texlive"
subpackages="$pkgname-dev $pkgname-doc"
source="https://www.nntb.no/~dreibh/sctplib/download/$pkgname-$pkgver.tar.gz"
options="!check" # No test suite defined in the upstream spec

prepare() {
	default_prepare
	autoreconf -i
}

build() {
	export CFLAGS="$CFLAGS -ffat-lto-objects"
	export CXXFLAGS="$CXXFLAGS -ffat-lto-objects"
	
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var \
		--enable-sctp-over-udp \
		--disable-maintainer-mode
	make
}

package() {
	make DESTDIR="$pkgdir" install
	
	# Delete libtool archive files as per Alpine policy
	find "$pkgdir" -name "*.la" -delete

	# Manually copy the PDF documentation into the package directory
	mkdir -p "$pkgdir"/usr/share/doc/$pkgname
	cp sctplib/manual/*.pdf "$pkgdir"/usr/share/doc/$pkgname/
}

sha512sums="
6e7270fa2a9f74bf4182010893afeca2877373c088af6f20d134e50d753d68af72481fbc45f6f5e48c39aa4af7886e7091eca59b8461d2fac9c05fc70dd62eb4  sctplib-1.0.34.tar.gz
"
